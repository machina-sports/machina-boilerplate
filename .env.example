# Server-only pod credentials. Never prefix these with NEXT_PUBLIC_.
MACHINA_API_URL=https://your-project.org.machina.gg
MACHINA_API_KEY=

# Agent selected by the chat UI.
MACHINA_AGENT=machina-assistant-executor

# Optional white-label settings.
NEXT_PUBLIC_APP_NAME={{APP_NAME}}
NEXT_PUBLIC_BRAND=default
